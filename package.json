{
  "name": "fluxo-desktop",
  "private": true,
  "version": "0.1.13",
  "type": "module",
  "description": "Fluxo multi-tenant ERP desktop client built with Tauri, React, TanStack Router, TanStack Query, Axios and Tailwind CSS v4.",
  "homepage": "https://github.com/Janeirohurley/fluxo-desktop",
  "bugs": {
    "url": "https://github.com/Janeirohurley/fluxo-desktop/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Janeirohurley/fluxo-desktop.git"
  },
  "author": "Janeiro Hurley",
  "license": "UNLICENSED",
  "keywords": [
    "fluxo",
    "erp",
    "desktop",
    "react",
    "tauri",
    "multi-tenant"
  ],
  "packageManager": "pnpm@10.21.0",
  "scripts": {
    "dev": "pnpm run router && vite",
    "build": "pnpm run router && tsc && vite build",
    "build:desktop": "pnpm run build && tauri build",
    "preview": "vite preview",
    "router": "npx @tanstack/router-cli generate --project ./src --output ./src/routeTree.gen.ts",
    "tauri": "tauri",
    "generate:module": "node folderGenerator.js",
    "check": "tsc -p tsconfig.json",
    "sync:tauri-version": "node scripts/sync-tauri-version.js",
    "release": "standard-version",
    "postbump": "pnpm run sync:tauri-version && git add package.json src-tauri/Cargo.toml src-tauri/tauri.conf.json",
    "release:push": "git push --follow-tags origin main"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@tanstack/react-query": "^5.90.6",
    "@tanstack/react-router": "^1.131.30",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-process": "~2.3.1",
    "@tauri-apps/plugin-updater": "~2.10.0",
    "axios": "^1.13.1",
    "dexie": "^4.4.1",
    "framer-motion": "^12.38.0",
    "i18next": "^26.0.1",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "^0.525.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-i18next": "^17.0.1",
    "sonner": "^2.0.6",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.12",
    "@tanstack/router-cli": "^1.131.30",
    "@tauri-apps/cli": "^2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "prompts": "^2.4.2",
    "standard-version": "^9.5.0",
    "tailwindcss": "^4.1.12",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  }
}
