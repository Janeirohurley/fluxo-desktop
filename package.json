{
  "name": "fluxo-desktop",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Fluxo desktop and web client built with React, reusable custom UI, TanStack Query, TanStack Router, Axios and Tailwind CSS v4.",
  "scripts": {
    "dev": "pnpm run router && vite",
    "build": "pnpm run router && tsc && vite build",
    "preview": "vite preview",
    "router": "npx @tanstack/router-cli generate --project ./src --output ./src/routeTree.gen.ts",
    "tauri": "tauri",
    "generate:module": "node folderGenerator.js",
    "check": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.90.6",
    "@tanstack/react-router": "^1.131.30",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "axios": "^1.13.1",
    "lucide-react": "^0.525.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "sonner": "^2.0.6"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.12",
    "@tanstack/router-cli": "^1.131.30",
    "@tauri-apps/cli": "^2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "prompts": "^2.4.2",
    "tailwindcss": "^4.1.12",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  }
}
