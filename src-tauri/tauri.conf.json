{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Fluxo Desktop",
  "version": "0.1.0",
  "identifier": "com.janeirohuley.fluxo-desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Fluxo",
        "width": 800,
        "height": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://raw.githubusercontent.com/JaneiroHurley/fluxo-desktop/main/update.json"
      ],
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDVFMkMxNTdGOURFNTdCN0MKUldSOGUrV2RmeFVzWHJTLy9zM1pYb2NEck12U1pueFEzMm50b3JTQ1FsUWptQVF3NVczeTVFK0oK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
